<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AlbumMundial2026" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/verde_mundial</item>
        <item name="colorPrimaryDark">@color/verde_oscuro</item>
        <item name="colorAccent">@color/amarillo_copa</item>
        <item name="android:statusBarColor">@color/verde_oscuro</item>
    </style>

    <!-- Botones de filtro compactos -->
    <style name="BtnFiltro" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">34dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:padding">2dp</item>
        <item name="android:textColor">@android:color/white</item>
    </style>
</resources>
